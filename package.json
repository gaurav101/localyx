{
  "name": "@gks101/localyx",
  "version": "1.0.1",
  "description": "A React hook for robust local storage state management with TTL and cross-tab sync.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --minify",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "react",
    "react-hooks",
    "hooks",
    "useLocalStorage",
    "useLocalStorageState",
    "localstorage",
    "localstorage-state",
    "state-management",
    "ttl",
    "time-to-live",
    "expiry",
    "cache",
    "sync",
    "cross-tab-sync",
    "encryption",
    "secure-storage",
    "ssr-safe",
    "nextjs",
    "typescript"
  ],
  "author": "Gaurav",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaurav101/localyx.git"
  },
  "bugs": {
    "url": "https://github.com/gaurav101/localyx/issues"
  },
  "homepage": "https://localyx.vercel.app/",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  }
}
